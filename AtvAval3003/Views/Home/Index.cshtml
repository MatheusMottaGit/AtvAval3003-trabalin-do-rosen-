@{
    ViewData["Title"] = "Home";
}

<div class="home-hero py-5 mb-5 shadow-sm rounded-4 bg-white text-center border">
    <div class="container py-4">

        <div class="mb-4">
            <img src="data:image/jpeg;base64,"
                 alt="Rosenclever"
                 class="img-fluid rounded-circle border border-4 border-light shadow-sm professor-img" />
        </div>

        <div class="d-flex align-items-center justify-content-center gap-3 mb-2 flex-wrap">
            <h1 class="display-5 fw-light text-dark mb-0 letter-spacing-tight">
                TRABALHIN DO <span class="fw-bold text-primary">ROSENCLEVER</span>
            </h1>
            <img src="data:image/jpeg;base64,"
                 alt="CRF"
                 class="flamengo-crest" />
        </div>

        <p class="text-muted mt-3 mb-4 text-uppercase small tracking-widest">
            Desenvolvido por <span class="text-dark fw-bold">Arthur Gama</span> & <span class="text-dark fw-bold">Matheus Motta</span><br />
            <span class="fw-light">Sistemas de Informação • 2026</span>
        </p>

        <hr class="my-4 mx-auto divider-clean">

        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <a asp-controller="Projeto" asp-action="Index" class="btn-clean btn-dark-minimal">
                VER PROJETOS
            </a>
            <a href="#sobre" class="btn-clean btn-outline-minimal">
                SAIBA MAIS
            </a>
        </div>
    </div>
</div>

<div class="container mt-5" id="sobre">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-4 border rounded-4 bg-white shadow-sm h-100 feature-card">
                <i class="bi bi-code-slash h2 text-primary"></i>
                <h5 class="fw-bold mt-3">ASP.NET Core</h5>
                <p class="text-muted small">Arquitetura MVC robusta e escalável para web apps modernos.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-4 bg-white shadow-sm h-100 feature-card">
                <i class="bi bi-database h2 text-primary"></i>
                <h5 class="fw-bold mt-3">Repository</h5>
                <p class="text-muted small">Padrão desacoplado garantindo facilidade em testes e manutenção.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-4 bg-white shadow-sm h-100 feature-card">
                <i class="bi bi-check-circle h2 text-primary"></i>
                <h5 class="fw-bold mt-3">Validações</h5>
                <p class="text-muted small">Segurança e integridade de dados via Data Annotations.</p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tipografia e Espaçamento */
    .letter-spacing-tight {
        letter-spacing: -1.5px;
    }

    .tracking-widest {
        letter-spacing: 2px;
    }

    .professor-img {
        width: 160px;
        height: 160px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

        .professor-img:hover {
            transform: scale(1.05);
        }

    .flamengo-crest {
        width: 50px;
        height: auto;
    }

    .divider-clean {
        width: 60px;
        height: 2px;
        background-color: #0d6efd;
        border: none;
        opacity: 1;
    }

    /* Botões Minimalistas */
    .btn-clean {
        display: inline-block;
        padding: 12px 32px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-decoration: none;
        text-transform: uppercase;
        border-radius: 6px;
        transition: all 0.25s ease;
    }

    .btn-dark-minimal {
        background-color: #121212;
        color: #fff;
        border: 1px solid #121212;
    }

        .btn-dark-minimal:hover {
            background-color: #333;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .btn-outline-minimal {
        background-color: transparent;
        color: #555;
        border: 1px solid #ddd;
    }

        .btn-outline-minimal:hover {
            background-color: #f8f9fa;
            color: #000;
            border-color: #bbb;
            transform: translateY(-3px);
        }

    /* Cards de Recursos */
    .feature-card {
        transition: all 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            border-color: #0d6efd !important;
        }
</style>