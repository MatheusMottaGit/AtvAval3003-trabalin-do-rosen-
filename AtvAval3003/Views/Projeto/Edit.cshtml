@model academico.Models.Projeto

@{
    ViewData["Title"] = "Editar Projeto";
}

<div class="container mt-5">
    <div class="mb-4 border-bottom pb-2">
        <h2 class="fw-light text-dark mb-0">Editar Detalhes</h2>
        <small class="text-muted text-uppercase" style="letter-spacing: 1px;">Projeto #@Model.ProjetoId</small>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="ProjetoId" />

                        <div class="form-group mb-3">
                            <label asp-for="Nome" class="form-label small fw-bold text-muted text-uppercase"></label>
                            <input asp-for="Nome" class="form-control form-control-clean" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group mb-3">
                                    <label asp-for="Sigla" class="form-label small fw-bold text-muted text-uppercase"></label>
                                    <input asp-for="Sigla" class="form-control form-control-clean text-uppercase" />
                                    <span asp-validation-for="Sigla" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label asp-for="Ano" class="form-label small fw-bold text-muted text-uppercase"></label>
                                    <input asp-for="Ano" class="form-control form-control-clean" />
                                    <span asp-validation-for="Ano" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Status" class="form-label small fw-bold text-muted text-uppercase"></label>
                            <select asp-for="Status"
                                    class="form-select form-control-clean"
                                    asp-items="Html.GetEnumSelectList<academico.Models.StatusProjeto>()">
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn-clean btn-dark-minimal flex-grow-1">
                                ATUALIZAR
                            </button>
                            <a asp-action="Index" class="btn-clean btn-outline-minimal text-center">
                                VOLTAR
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Reaproveitando os estilos da Home/Index */
    .form-control-clean {
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        padding: 10px 15px;
        font-size: 0.9rem;
        transition: border-color 0.2s;
    }

        .form-control-clean:focus {
            border-color: #0d6efd;
            box-shadow: none;
            background-color: #fcfcfc;
        }

    .btn-clean {
        display: inline-block;
        padding: 10px 20px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-decoration: none;
        text-transform: uppercase;
        border-radius: 6px;
        transition: all 0.25s ease;
        border: 1px solid transparent;
    }

    .btn-dark-minimal {
        background-color: #121212;
        color: #fff;
    }

        .btn-dark-minimal:hover {
            background-color: #333;
            transform: translateY(-2px);
        }

    .btn-outline-minimal {
        background-color: transparent;
        color: #666;
        border-color: #ddd;
    }

        .btn-outline-minimal:hover {
            background-color: #f8f9fa;
            transform: translateY(-2px);
        }

    .form-label {
        letter-spacing: 0.5px;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}