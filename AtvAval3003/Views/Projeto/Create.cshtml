@model academico.Models.Projeto

@{
    ViewData["Title"] = "Cadastrar Novo Projeto";
}

<h1>Cadastrar</h1>

<h4>Projeto</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Removido o campo de ProjetoId pois ele é gerado pelo Repository *@

            <div class="form-group mb-3">
                <label asp-for="Nome" class="control-label font-weight-bold"></label>
                <input asp-for="Nome" class="form-control" placeholder="Ex: Sistema de Gestão" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Sigla" class="control-label font-weight-bold"></label>
                <input asp-for="Sigla" class="form-control" placeholder="Ex: SGA (sem espaços)" />
                <span asp-validation-for="Sigla" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Ano" class="control-label font-weight-bold"></label>
                <input asp-for="Ano" class="form-control" />
                <span asp-validation-for="Ano" class="text-danger"></span>
            </div>

            @* Implementação da Caixa de Seleção para o Enum *@
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label font-weight-bold"></label>
                <select asp-for="Status"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<academico.Models.StatusProjeto>()">
                    <option value="">-- Selecione o Status --</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Salvar Projeto" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Voltar para a listagem</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}