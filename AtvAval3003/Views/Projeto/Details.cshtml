@model academico.Models.Projeto

@{
    ViewData["Title"] = "Detalhes do Projeto";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-light text-dark mb-0">Visão Geral</h2>
            <small class="text-muted text-uppercase" style="letter-spacing: 1px;">Especificações do Projeto</small>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.ProjetoId" class="btn-clean btn-dark-minimal py-2">
                EDITAR PROJETO
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="small fw-bold text-muted text-uppercase d-block mb-1" style="letter-spacing: 0.5px;">Nome do Projeto</label>
                        <h3 class="fw-bold text-dark">@Model.Nome</h3>
                    </div>

                    <div class="row g-4">
                        <div class="col-sm-4">
                            <label class="small fw-bold text-muted text-uppercase d-block mb-1">Sigla</label>
                            <span class="text-dark fs-5">@Model.Sigla</span>
                        </div>
                        <div class="col-sm-4">
                            <label class="small fw-bold text-muted text-uppercase d-block mb-1">Ano de Referência</label>
                            <span class="text-dark fs-5">@Model.Ano</span>
                        </div>
                        <div class="col-sm-4">
                            <label class="small fw-bold text-muted text-uppercase d-block mb-1">Identificador</label>
                            <span class="text-secondary fs-5">#@Model.ProjetoId</span>
                        </div>
                        
                        <div class="col-12">
                            <hr class="text-light" />
                            <label class="small fw-bold text-muted text-uppercase d-block mb-2">Status Atual</label>
                            <div class="d-flex align-items-center">
                                <span class="status-dot @Model.Status.ToString().ToLower()"></span>
                                <span class="text-dark fw-medium">
                                    @(Model.Status switch {
                                        academico.Models.StatusProjeto.EmDesenvolvimento => "Em desenvolvimento",
                                        academico.Models.StatusProjeto.EmCondicoesDeDefesa => "Em condições de defesa",
                                        academico.Models.StatusProjeto.CompletoSemImplantar => "Completo (não implantado)",
                                        academico.Models.StatusProjeto.Implantado => "Implantado",
                                        _ => Model.Status.ToString()
                                    })
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-4">
                <a asp-action="Index" class="btn-clean btn-outline-minimal">
                    ← VOLTAR PARA LISTAGEM
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Reaproveitando os estilos minimalistas */
    .btn-clean {
        display: inline-block;
        padding: 10px 25px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-decoration: none;
        text-transform: uppercase;
        border-radius: 6px;
        transition: all 0.25s ease;
        border: 1px solid transparent;
    }

    .btn-dark-minimal {
        background-color: #121212;
        color: #fff !important;
    }

    .btn-dark-minimal:hover {
        background-color: #333;
        transform: translateY(-2px);
    }

    .btn-outline-minimal {
        background-color: transparent;
        color: #666;
        border-color: #ddd;
    }

    .btn-outline-minimal:hover {
        background-color: #f8f9fa;
        color: #333;
    }

    /* Indicador de Status */
    .status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 8px;
    }
    .emdesenvolvimento { background-color: #0dcaf0; }
    .emcondicoesdedefesa { background-color: #ffc107; }
    .completosemimplantar { background-color: #6c757d; }
    .implantado { background-color: #198754; }
</style>